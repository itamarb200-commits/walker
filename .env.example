# ── Supabase (Phase 1) ────────────────────────────────────────────────────────
# Project → Settings → API. The anon key is safe for the browser (RLS protects
# data); the service-role key is SERVER ONLY — never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Push reminders (Phase 4) ──────────────────────────────────────────────────
# Generate a pair with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:itamarb200@gmail.com

# Shared secret the scheduler (GitHub Actions) sends to trigger reminders.
CRON_SECRET=
